# Dependencies & build output
node_modules
dist
coverage
*.local
.DS_Store
*.log
npm-debug.log*

# Editor / OS
.idea
.vscode/*
!.vscode/extensions.json
.vite

# Capacitor native projects (generated by `cap add`).
# NOTE: when native projects are added in Phase 3 these blanket ignores will be
# narrowed so the committed project carries custom config (PrivacyInfo.xcprivacy,
# AndroidManifest edits, signing config templates). Until then, ignore wholesale.
/android
/ios

# TypeScript incremental build info
*.tsbuildinfo

# Build artifacts from the solver test harness
tools/*.cjs
tools/*.js.map

# ---- SECRETS / SIGNING MATERIAL — never commit -------------------------------
*.jks
*.keystore
keystore.properties
*.p8
*.p12
*.mobileprovision
*.cer
*.certSigningRequest
.env
.env.*
!.env.example
# Firebase / Google services configs may carry project identifiers
google-services.json
GoogleService-Info.plist
# fastlane local state
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots
fastlane/test_output
**/.secrets
